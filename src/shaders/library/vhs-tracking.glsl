float hash(vec2 p){return fract(sin(dot(p,vec2(127.1,311.7)))*43758.5453);}void main(){vec2 uv=gl_FragCoord.xy/u_res.xy;float t=u_time*u_speed;float band=fract(uv.y+t*0.13);float tb=smoothstep(0.0,0.05,band)*smoothstep(0.12,0.05,band);float jit=(hash(vec2(floor(uv.y*90.0),floor(t*15.0)))-0.5)*0.012;vec2 q=uv;q.x+=tb*0.22*(hash(vec2(floor(t*11.0),1.0))-0.3)+jit;float hue=floor(q.x*6.0*u_scale)/6.0;vec3 colR=0.5+0.5*cos(6.28318*(hue+0.006+t*0.02+vec3(0.0,0.33,0.67)));vec3 colG=0.5+0.5*cos(6.28318*(hue+t*0.02+vec3(0.0,0.33,0.67)));vec3 colB=0.5+0.5*cos(6.28318*(hue-0.006+t*0.02+vec3(0.0,0.33,0.67)));vec3 col=vec3(colR.r,colG.g,colB.b)*(0.6+0.25*sin(q.y*7.0+t));col=mix(col,vec3(hash(q*vec2(310.0,170.0)+t*60.0)),tb*0.8);float head=smoothstep(0.06,0.02,uv.y);col=mix(col,vec3(hash(vec2(uv.x*200.0,floor(t*30.0)))*0.7),head);col*=0.88+0.12*sin(uv.y*u_res.y*1.8);col*=1.0-0.25*step(0.992,hash(vec2(floor(t*7.0),3.0)));outColor=vec4(audioPop(col*u_intensity),1.0);}
