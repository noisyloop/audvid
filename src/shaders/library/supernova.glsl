float noise(vec2 p){return fract(sin(dot(p,vec2(12.9898,78.233)))*43758.5453);}void main(){vec2 uv=gl_FragCoord.xy/u_res.xy;vec2 p=(uv-0.5)*u_scale;p.x*=u_res.x/u_res.y;float t=u_time*u_speed;float r=length(p);float a=atan(p.y,p.x);vec3 col=vec3(0.0);float core=smoothstep(0.1,0.0,r);col+=vec3(1.0,0.95,0.9)*core;float corona=smoothstep(0.3,0.0,r)*(1.0-core);col+=vec3(1.0,0.6,0.2)*corona;for(float i=0.0;i<12.0;i++){float rayA=i*0.523599+t*0.3+noise(vec2(i,floor(t)))*0.5;float raySpread=0.1+0.1*noise(vec2(i+100.0,t));float ray=smoothstep(raySpread,0.0,abs(mod(a-rayA+3.14159,6.28318)-3.14159))*smoothstep(0.0,0.5,r)*smoothstep(1.0,0.2,r);col+=mix(vec3(1.0,0.8,0.3),vec3(1.0,0.3,0.1),noise(vec2(i,0.0)))*ray*0.5*u_intensity;}col+=vec3(0.5,0.7,1.0)*smoothstep(0.02,0.0,abs(r-0.4-sin(t)*0.1))*u_intensity;outColor=vec4(col,1.0);}
