// name: NOISE TERRAIN
// category: nature
// ported from prism-video-synth
float noise(vec2 p){return fract(sin(dot(p,vec2(12.9898,78.233)))*43758.5453);}float sn(vec2 p){vec2 i=floor(p);vec2 f=fract(p);f=f*f*(3.0-2.0*f);return mix(mix(noise(i),noise(i+vec2(1.0,0.0)),f.x),mix(noise(i+vec2(0.0,1.0)),noise(i+vec2(1.0,1.0)),f.x),f.y);}float fbm(vec2 p){float v=0.0,a=0.5;for(int i=0;i<5;i++){v+=a*sn(p);p*=2.0;a*=0.5;}return v;}void main(){vec2 uv=gl_FragCoord.xy/u_res.xy;float t=u_time*u_speed*0.2;float terrain=fbm(vec2(uv.x*5.0*u_scale+t,t*0.5));float height=terrain*0.4+0.3;vec3 col=vec3(0.1,0.0,0.2);if(uv.y<height){float h=(height-uv.y)/height;col=mix(vec3(0.0,0.3,0.1),vec3(0.4,0.2,0.0),h);col=mix(col,vec3(0.8,0.8,0.9),smoothstep(0.35,0.4,height));}else{col=mix(vec3(0.8,0.4,0.2),vec3(0.1,0.0,0.3),(uv.y-height)/(1.0-height));}outColor=vec4(audioPop(col*u_intensity),1.0);}
