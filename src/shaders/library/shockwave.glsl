float hash(vec2 p){return fract(sin(dot(p,vec2(127.1,311.7)))*43758.5453);}void main(){vec2 uv=(gl_FragCoord.xy-u_res.xy*0.5)/u_res.y;float t=u_time*u_speed;vec2 p=uv*1.6*u_scale;float r=length(p);float cyc=floor(t*0.45);float wr=fract(t*0.45)*1.9;vec2 dir=r>0.001?p/r:vec2(0.0);vec2 q=p+dir*0.1*exp(-abs(r-wr)*7.0)*sin((r-wr)*30.0);vec2 g=abs(fract(q*4.0)-0.5);float grid=smoothstep(0.06,0.02,min(g.x,g.y))*0.4;float front=exp(-abs(r-wr)*14.0);float flash=exp(-r*3.0)*exp(-fract(t*0.45)*6.0)*2.0;float sparks=0.0;for(int i=0;i<14;i++){float fi=float(i);float sa=hash(vec2(fi,cyc))*6.28318;float sr=wr*(0.75+0.25*hash(vec2(fi,cyc+0.5)));vec2 sp=sr*vec2(cos(sa),sin(sa));sparks+=exp(-length(p-sp)*55.0);}vec3 col=vec3(0.04,0.02,0.08)+(0.5+0.5*cos(6.28318*(r*0.4-t*0.2+vec3(0.0,0.33,0.67))))*grid;col+=vec3(1.0,0.55,0.2)*front*(0.7+0.3*sin(r*40.0-t*8.0));col+=vec3(1.0,0.85,0.6)*flash+vec3(1.0,0.8,0.5)*sparks*0.9;outColor=vec4(audioPop(col*u_intensity),1.0);}
