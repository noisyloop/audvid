vec2 hash2(vec2 p){return fract(sin(vec2(dot(p,vec2(127.1,311.7)),dot(p,vec2(269.5,183.3))))*43758.5453);}
void main(){vec2 uv=(gl_FragCoord.xy-u_res.xy*0.5)/u_res.y;float t=u_time*u_speed;vec2 p=uv*4.0*u_scale;vec2 id=floor(p);vec2 f=fract(p);vec3 col=vec3(0.01,0.02,0.05);for(int j=-1;j<=1;j++)for(int i=-1;i<=1;i++){vec2 g=vec2(float(i),float(j));vec2 o=g+0.5+0.32*sin(t*0.5+6.28318*hash2(id+g))-f;for(int j2=-1;j2<=1;j2++)for(int i2=-1;i2<=1;i2++){if(i2>i||(i2==i&&j2>j)){vec2 g2=vec2(float(i2),float(j2));vec2 o2=g2+0.5+0.32*sin(t*0.5+6.28318*hash2(id+g2))-f;vec2 ba=o2-o;float ll=length(ba);if(ll<1.45){float h=clamp(dot(-o,ba)/dot(ba,ba),0.0,1.0);float d=length(-o-ba*h);float sig=exp(-pow((h-fract(t*0.7+dot(id+g,vec2(0.17,0.31))))*4.0,2.0));col+=vec3(0.1,0.45,0.7)*smoothstep(0.025,0.005,d)*(1.0-ll*0.5)*0.45;col+=vec3(0.4,1.0,0.9)*sig*exp(-d*55.0)*0.6;}}}float nd=length(o);float pulse=0.6+0.4*sin(t*2.5+hash2(id+g).x*9.0);col+=vec3(0.2,0.85,1.0)*exp(-nd*16.0)*pulse;}outColor=vec4(col*u_intensity,1.0);}
