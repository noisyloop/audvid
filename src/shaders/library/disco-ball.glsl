float hash(vec2 p){return fract(sin(dot(p,vec2(127.1,311.7)))*43758.5453);}void main(){vec2 uv=gl_FragCoord.xy/u_res.xy;vec2 p=(uv-0.5)*u_scale;p.x*=u_res.x/u_res.y;float t=u_time*u_speed;float r=length(p);float a=atan(p.y,p.x)+t*0.5;vec3 col=vec3(0.0);float tiles=20.0;vec2 tileId=vec2(floor(a*tiles/6.28318),floor(r*tiles));float h=hash(tileId);float sparkle=pow(sin(t*5.0+h*20.0)*0.5+0.5,10.0);float sphere=smoothstep(0.5,0.48,r);col+=(0.5+0.5*cos(h*6.28318+t+vec3(0.0,2.0,4.0)))*sparkle*sphere*u_intensity+vec3(0.2)*sphere*0.3;for(float i=0.0;i<8.0;i++){float rayA=i*0.785398+t;vec2 rayDir=vec2(cos(rayA),sin(rayA));col+=vec3(1.0)*pow(max(0.0,dot(normalize(p),rayDir)),50.0)*smoothstep(0.5,0.8,r)*0.3*u_intensity;}outColor=vec4(audioPop(col),1.0);}
