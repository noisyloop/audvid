// name: PINWHEEL TILES
// category: tiling
// ported from prism-video-synth
float hash(vec2 p){return fract(sin(dot(p,vec2(127.1,311.7)))*43758.5453);}mat2 rot(float a){float c=cos(a),s=sin(a);return mat2(c,-s,s,c);}void main(){vec2 uv=(gl_FragCoord.xy-u_res.xy*0.5)/u_res.y;float t=u_time*u_speed;vec2 p=uv*4.0*u_scale;vec2 id=floor(p);vec2 f=fract(p)-0.5;float h=hash(id);f=rot(t*(h-0.5)*2.5+h*6.28318)*f;float q1=step(f.y,f.x);float q2=step(-f.x,f.y);float tri=q1+q2*2.0;float e=min(abs(f.x-f.y),abs(f.x+f.y));float border=min(0.5-abs(f.x),0.5-abs(f.y));float hue=h*0.3+tri*0.08+t*0.1;vec3 col=(0.5+0.5*cos(6.28318*(hue+vec3(0.0,0.33,0.67))))*(0.35+tri*0.18);col*=smoothstep(0.0,0.04,border);col+=vec3(1.0)*smoothstep(0.025,0.0,e)*(0.5+0.5*sin(t*2.0+h*9.0))*0.6;outColor=vec4(audioPop(col*u_intensity),1.0);}
