float hash(vec2 p){return fract(sin(dot(p,vec2(127.1,311.7)))*43758.5453);}float sn(vec2 p){vec2 i=floor(p);vec2 f=fract(p);f=f*f*(3.0-2.0*f);return mix(mix(hash(i),hash(i+vec2(1.0,0.0)),f.x),mix(hash(i+vec2(0.0,1.0)),hash(i+vec2(1.0,1.0)),f.x),f.y);}float fbm(vec2 p){float v=0.0,a=0.5;for(int i=0;i<5;i++){v+=a*sn(p);p*=2.03;a*=0.5;}return v;}void main(){vec2 uv=(gl_FragCoord.xy-u_res.xy*0.5)/u_res.y;float t=u_time*u_speed;vec2 p=uv*2.5*u_scale;p.y+=t*0.12;vec2 q=vec2(fbm(p+vec2(0.0,t*0.3)),fbm(p+vec2(5.2,t*0.2)));vec2 r=vec2(fbm(p+q*2.0+vec2(1.7,9.2)+t*0.15),fbm(p+q*2.0+vec2(8.3,2.8)-t*0.13));float f=fbm(p+r*2.5);float hue=f*1.2+q.x*0.5+t*0.1;vec3 col=(0.5+0.5*cos(6.28318*(hue+vec3(0.0,0.33,0.67))))*(f*f*1.8+0.2);col+=(0.5+0.5*cos(6.28318*(hue+0.5+vec3(0.0,0.33,0.67))))*pow(r.x,3.0)*0.6;outColor=vec4(col*u_intensity,1.0);}
