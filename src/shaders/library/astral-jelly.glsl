float hash(vec2 p){return fract(sin(dot(p,vec2(127.1,311.7)))*43758.5453);}float sn(vec2 p){vec2 i=floor(p);vec2 f=fract(p);f=f*f*(3.0-2.0*f);return mix(mix(hash(i),hash(i+vec2(1.0,0.0)),f.x),mix(hash(i+vec2(0.0,1.0)),hash(i+vec2(1.0,1.0)),f.x),f.y);}void main(){vec2 uv=(gl_FragCoord.xy-u_res.xy*0.5)/u_res.y;float t=u_time*u_speed;vec2 p=uv*1.5*u_scale;p.y-=0.12;float r=length(p);float a=atan(p.y,p.x);float R=0.42+0.09*sin(a*3.0+t)+0.05*sin(a*7.0-t*1.3)+0.03*sin(a*11.0+t*0.7);float d=r-R;float body=smoothstep(0.02,-0.06,d);float rim=exp(-abs(d)*22.0);float organ=sn(p*6.0+t*0.3)*body;vec3 col=(0.5+0.5*cos(6.28318*(d*0.6+t*0.1+vec3(0.0,0.33,0.67))))*body*(0.25+0.25*sin(d*35.0-t*2.5));col+=(0.5+0.5*cos(6.28318*(0.6+a*0.1+t*0.12+vec3(0.0,0.33,0.67))))*rim*0.9;col+=vec3(0.9,0.5,1.0)*organ*0.35;float tent=0.0;for(int i=0;i<7;i++){float fi=float(i);float tx=(fi/3.0-1.0)*0.33;float wig=sin(p.y*6.0+t*2.0+fi*1.7)*0.07*clamp(-p.y,0.0,1.0);tent+=smoothstep(0.015,0.0,abs(p.x-tx-wig))*smoothstep(0.1,-0.2,p.y+R*0.5);}col+=(0.5+0.5*cos(6.28318*(0.8+t*0.1+vec3(0.0,0.33,0.67))))*tent*0.5;outColor=vec4(col*u_intensity,1.0);}
